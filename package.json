{
  "name": "patente-quiz",
  "version": "0.1.0",
  "description": "Local-first study tool for Italian driving license theory exam practice questions",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "import": "tsx src/scripts/import.ts && wrangler d1 execute DB --local --file=data/seed.sql",
    "dev:server": "wrangler dev",
    "dev:client": "vite --config src/client/vite.config.ts src/client",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\""
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260628.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wrangler": "^4.105.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "sharp@0.34.5": true,
    "workerd@1.20260625.1": true,
    "wrangler@4.105.0": true
  }
}
